# URL base del backend (API Gateway HTTP API o servidor local `go run .`).
# En Vercel configurar: VITE_API_URL=https://<api-id>.execute-api.<region>.amazonaws.com
# Sin definir, el front usa http://localhost:8080 (backend local).
VITE_API_URL=http://localhost:8080

# ID del usuario/agente cuyo perfil alimenta el sitio público y la configuración.
# Sin definir, el front usa el primer usuario que devuelve GET /users.
VITE_PROFILE_USER_ID=936a9e97eec013dd9d41baefd6ddf944

# ── AWS Cognito (Etapa 2 — autenticación OIDC vía Hosted UI) ─────────────────
# Único método de acceso al panel. Sin estas variables la app usa el acceso
# simulado (desarrollo local). Ver docs/AUTH_COGNITO.md para el setup en AWS.
# Dominio del Hosted UI (Cognito → App integration → Domain), URL completa:
# https://<prefijo>.auth.<región>.amazoncognito.com
VITE_COGNITO_DOMAIN=
# App client del User Pool con "Authorization code grant" habilitado y la
# callback URL registrada (raíz del sitio: http://localhost:5173/ en dev).
VITE_COGNITO_CLIENT_ID=
# Secret del app client (cliente confidencial). Nota: en una SPA el secret
# queda embebido en el bundle; un app client público con PKCE no lo necesita.
VITE_COGNITO_CLIENT_SECRET=
