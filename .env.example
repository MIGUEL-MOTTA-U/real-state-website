# URL base del backend (API Gateway HTTP API o servidor local `go run .`).
# En Vercel configurar: VITE_API_URL=https://<api-id>.execute-api.<region>.amazonaws.com
# Sin definir, el front usa http://localhost:8080 (backend local).
VITE_API_URL=http://localhost:8080

# ID del usuario/agente cuyo perfil alimenta el sitio público y la configuración.
# Sin definir, el front usa el primer usuario que devuelve GET /users.
VITE_PROFILE_USER_ID=936a9e97eec013dd9d41baefd6ddf944

# ── AWS Cognito (Etapa 2 — autenticación del panel) ──────────────────────────
# Sin estas variables la app usa el login simulado (desarrollo local).
# Ver docs/AUTH_COGNITO.md para la configuración completa en AWS.
# Región del User Pool (ej. us-east-1).
VITE_COGNITO_REGION=
# App client del User Pool: SIN client secret y con ALLOW_USER_PASSWORD_AUTH
# habilitado (Auth flows del app client).
VITE_COGNITO_CLIENT_ID=
# ID del User Pool (ej. us-east-1_AbCdEfGhI). Informativa para el front, y es
# la que define el issuer del JWT authorizer en API Gateway.
VITE_COGNITO_USER_POOL_ID=
