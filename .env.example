# URL base del backend (API Gateway HTTP API o servidor local `go run .`).
# En Vercel configurar: VITE_API_URL=https://<api-id>.execute-api.<region>.amazonaws.com
# Sin definir, el front usa http://localhost:8080 (backend local).
VITE_API_URL=http://localhost:8080

# ID del usuario/agente cuyo perfil alimenta el sitio público y la configuración.
# Sin definir, el front usa el primer usuario que devuelve GET /users.
VITE_PROFILE_USER_ID=936a9e97eec013dd9d41baefd6ddf944
